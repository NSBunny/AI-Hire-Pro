# Copy this file to .env and configure your live credentials if desired.
# If these are left blank, the system automatically runs in local offline mode
# using the local JSON database (db.json) and simulated AI prompts.

# Neon PostgreSQL connection string (e.g. postgresql://user:password@host/db?sslmode=require)
DATABASE_URL=

# Google Gemini API key
GEMINI_API_KEY=
